# Ignore local llama.cpp working/build directories used for backend-specific experiments.
llama.cpp-*/
reference/llama.cpp-*/

# Ignore captured setup and benchmark outputs while keeping directory docs tracked.
00-setup/results/*
!00-setup/results/README.md
01-hardware/results/*
!01-hardware/results/README.md
02-operators/results/*
!02-operators/results/README.md
03-openvino/results/*
!03-openvino/results/README.md
03-openvino/models/*
!03-openvino/models/README.md
03-openvino/assets/*
!03-openvino/assets/README.md
04-llama.cpp/results/*
!04-llama.cpp/results/README.md
05-vllm/results/*
!05-vllm/results/README.md
05-vllm/vllm/
05-vllm/vllm-openvino/

# Ignore Python bytecode caches from local validation runs.
__pycache__/
*.pyc
